# PubNub keys (publish + subscribe are safe in client bundle)
NEXT_PUBLIC_PUBNUB_PUBLISH_KEY=pub-c-...
NEXT_PUBLIC_PUBNUB_SUBSCRIBE_KEY=sub-c-...
# Server-only PubNub secret (mints PAM tokens, do NOT expose)
PUBNUB_SECRET_KEY=sec-c-...

# Postgres (Railway injects DATABASE_URL automatically when the Postgres add-on is attached)
DATABASE_URL=postgres://user:pass@host:5432/db

# Host gating (single shared password for /host)
HOST_PASSWORD=change-me

# Public app URL — used for QR generation. For local multi-device dev,
# set this to your LAN IP (e.g. http://192.168.1.42:3000) so phones can reach you.
NEXT_PUBLIC_APP_URL=http://localhost:3000
